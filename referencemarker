<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Surgical Eye Tracking HUD (Kappa Angle Corrected)</title>
    <script async src="https://docs.opencv.org/4.7.0/opencv.js" onload="onOpenCvReady();" type="text/javascript"></script>
    <style>
        body { margin: 0; overflow: hidden; background-color: #000; color: white; font-family: sans-serif; touch-action: none; }
        #container { position: relative; width: 100vw; height: 100vh; display: flex; justify-content: center; align-items: center; }
        video, canvas { position: absolute; max-width: 100%; max-height: 100%; object-fit: contain; }
        video { display: none; } 
        canvas { transform: scaleX(1); } 
        
        #ui-panel { 
            position: absolute; top: 10px; left: 10px; z-index: 10; 
            background: rgba(0, 0, 0, 0.7); padding: 15px; border-radius: 8px; 
            border: 1px solid #444; width: 260px; box-sizing: border-box;
        }
        
        .setting-group { margin-bottom: 12px; }
        label { font-size: 14px; font-weight: bold; color: #00FFFF; display: block; margin-bottom: 5px; }
        input[type=number] { width: 70px; padding: 6px; font-size: 16px; text-align: center; background: #222; color: #fff; border: 1px solid #666; border-radius: 4px; }

        .button-group { display: flex; flex-direction: column; gap: 8px; margin-top: 5px; }
        .action-btn { 
            width: 100%; padding: 10px; color: white; border: 1px solid #555; 
            border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: bold;
            transition: background 0.2s;
        }
        .action-btn { background-color: #007bff; border-color: #0056b3; }
        .action-btn:active { background-color: #0056b3; }

        .instruction { font-size: 11px; color: #aaa; margin-top: 10px; display: block; line-height: 1.4; }
        
        /* 마커 디자인 */
        #marker { display: none; position: absolute; border: 4px dashed #00FFFF; border-radius: 50%; pointer-events: none; z-index: 5; transform: translate(-50%, -50%); box-sizing: border-box;}
        #marker::before { content: attr(data-label); position: absolute; top: -25px; left: 50%; transform: translateX(-50%); font-weight: bold; font-size: 14px; text-shadow: 1px 1px 2px black; white-space: nowrap; }

        #loading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 20; font-size: 16px; font-weight: bold; color: #FFFF00; background: rgba(0,0,0,0.8); padding: 15px 20px; border-radius: 8px; text-align: center;}
    </style>
</head>
<body>

    <div id="loading">OpenCV 로딩 및 카메라 켜는 중...</div>

    <div id="ui-panel">
        <div class="setting-group">
            <label>목표 축(도): <input type="number" id="targetAngle" value="90" min="0" max="180"></label>
        </div>
        
        <div class="setting-group">
            <label id="statusLabel">수동 영점 (2단계 마킹)</label>
            <div class="button-group">
                <button class="action-btn" id="btnCaptureSnapshot" style="background-color: #444; border-color: #333;">마킹 스냅샷 찍기</button>
                <button class="action-btn" id="btnAction" style="display: none;">각막 완료 (다음: 동공)</button>
            </div>
        </div>

        <span class="instruction">
            1. [각막] 범위를 지정하여 트래킹 기준을 잡습니다.<br>
            2. [동공] 범위를 지정하여 각도기(HUD) 중심을 잡습니다.<br>
            (1/2손가락 터치 드래그 & 줌 지원)
        </span>
    </div>

    <div id="container">
        <video id="video" autoplay playsinline></video>
        <canvas id="canvas"></canvas>
        <div id="marker"></div>
    </div>

    <script>
        const videoElement = document.getElementById('video');
        const canvasElement = document.getElementById('canvas');
        const canvasCtx = canvasElement.getContext('2d');
        const marker = document.getElementById('marker');
        const loading = document.getElementById('loading');
        
        const angleInput = document.getElementById('targetAngle');
        const btnCaptureSnapshot = document.getElementById('btnCaptureSnapshot');
        const btnAction = document.getElementById('btnAction');
        const statusLabel = document.getElementById('statusLabel');

        let markingSnapshot = null;
        let limbusTemplate = null; 
        let trackedCenter = null;
        
        // --- 2단계 마킹용 상태 변수 ---
        // markingStep: 0=라이브, 1=각막 마킹, 2=동공 마킹, 3=트래킹 중
        let markingStep = 0; 
        let markerRect = { x: 0, y: 0, width: 200, height: 200 }; 
        
        let corneaRect = null;
        let pupilRect = null;
        let centerOffset = { dx: 0, dy: 0 }; // 각막 중심과 동공 중심의 오차 거리
        
        let corneaTrackingRadius = 100;
        let pupilTrackingRadius = 50;

        // --- 카메라 제어(광학 줌) 관련 변수 ---
        let videoTrack = null;
        let cameraCapabilities = null;
        let currentHardwareZoom = 1.0;
        let initialHardwareZoom = 1.0;

        // --- 터치 상태 변수 ---
        let isDragging = false;
        let lastTouchX = null;
        let lastTouchY = null;
        let initialPinchDistance = null;
        let initialMarkerWidth = 0;
        let lastMidpointX = null;
        let lastMidpointY = null;

        let isCvReady = false;

        function onOpenCvReady() {
            console.log("OpenCV.js Ready!");
            isCvReady = true;
            startStandardCamera();
        }

        async function startStandardCamera() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: 'environment', width: { ideal: 1280 }, height: { ideal: 720 }, focusMode: 'continuous' }
                });
                videoElement.srcObject = stream;
                videoTrack = stream.getVideoTracks()[0];
                
                videoElement.onloadedmetadata = () => {
                    videoElement.play();
                    loading.style.display = 'none';
                    
                    setTimeout(() => {
                        cameraCapabilities = videoTrack.getCapabilities ? videoTrack.getCapabilities() : null;
                        if (cameraCapabilities && cameraCapabilities.zoom) {
                            currentHardwareZoom = videoTrack.getSettings().zoom || cameraCapabilities.zoom.min;
                        }
                    }, 500);

                    requestAnimationFrame(processVideo);
                };
            } catch (err) {
                loading.innerText = "카메라 권한을 허용해주세요.";
            }
        }

        // 초기화 버튼 동작 (스냅샷 찍기 & 리셋)
        btnCaptureSnapshot.addEventListener('click', () => {
            if (markingStep !== 0) {
                // 초기화 (라이브 복귀)
                markingStep = 0;
                if (markingSnapshot) { markingSnapshot.delete(); markingSnapshot = null; }
                if (limbusTemplate) { limbusTemplate.delete(); limbusTemplate = null; }
                trackedCenter = null;

                btnCaptureSnapshot.textContent = "마킹 스냅샷 찍기";
                statusLabel.textContent = "수동 영점 (2단계 마킹)";
                btnAction.style.display = 'none';
                marker.style.display = 'none';
                return; 
            }

            if (videoElement.videoWidth === 0) return;

            const width = videoElement.videoWidth;
            const height = videoElement.videoHeight;
            const tempCanvas = document.createElement('canvas');
            tempCanvas.width = width; tempCanvas.height = height;
            tempCanvas.getContext('2d').drawImage(videoElement, 0, 0, width, height);
            
            const imgData = tempCanvas.getContext('2d').getImageData(0, 0, width, height);
            markingSnapshot = cv.matFromImageData(imgData);
            
            // 1단계: 각막(Limbus) 설정 시작
            markingStep = 1;
            statusLabel.textContent = "1/2. 각막(추적) 영역 설정";
            btnCaptureSnapshot.textContent = "초기화 (라이브 복귀)";
            
            marker.style.display = 'block';
            marker.style.borderColor = '#00FFFF'; // 시안색 (각막)
            marker.setAttribute('data-label', '각막(Limbus) 설정');
            marker.style.color = '#00FFFF';

            const initialDiameter = 200;
            markerRect = { 
                x: (width - initialDiameter) / 2, 
                y: (height - initialDiameter) / 2, 
                width: initialDiameter, height: initialDiameter 
            };
            updateMarkerUI();
            
            btnAction.textContent = "각막 완료 (다음: 동공)";
            btnAction.style.display = 'block';
        });

        // 단계 진행 액션 버튼 (다음 / 트래킹 시작)
        btnAction.addEventListener('click', () => {
            if (markingStep === 1) {
                // 각막 정보 저장
                corneaRect = { ...markerRect };
                corneaTrackingRadius = corneaRect.width / 2;

                // 2단계: 동공(Pupil) 설정 모드로 전환
                markingStep = 2;
                statusLabel.textContent = "2/2. 동공(중심) 영역 설정";
                
                // 마커를 작게, 자주색으로 변경하여 각막 중앙에 띄움
                const pupilDiameter = 80;
                markerRect.width = pupilDiameter;
                markerRect.height = pupilDiameter;
                markerRect.x = corneaRect.x + corneaRect.width/2 - pupilDiameter/2;
                markerRect.y = corneaRect.y + corneaRect.height/2 - pupilDiameter/2;
                
                marker.style.borderColor = '#FF00FF'; // 자주색 (동공)
                marker.setAttribute('data-label', '동공(Pupil) 중심 설정');
                marker.style.color = '#FF00FF';
                
                updateMarkerUI();
                btnAction.textContent = "동공 완료 (트래킹 시작)";
            
            } else if (markingStep === 2) {
                // 동공 정보 저장 및 템플릿 생성
                pupilRect = { ...markerRect };
                pupilTrackingRadius = pupilRect.width / 2;

                // 각막 중심과 동공 중심 간의 오차(Angle Kappa) 계산
                const corneaCx = corneaRect.x + corneaRect.width / 2;
                const corneaCy = corneaRect.y + corneaRect.height / 2;
                const pupilCx = pupilRect.x + pupilRect.width / 2;
                const pupilCy = pupilRect.y + pupilRect.height / 2;

                centerOffset.dx = pupilCx - corneaCx;
                centerOffset.dy = pupilCy - corneaCy;

                // 추적은 '각막(Cornea)' 기준으로 템플릿 추출
                let roiX = Math.floor(Math.max(0, corneaRect.x));
                let roiY = Math.floor(Math.max(0, corneaRect.y));
                let roiW = Math.floor(Math.min(markingSnapshot.cols - roiX, corneaRect.width));
                let roiH = Math.floor(Math.min(markingSnapshot.rows - roiY, corneaRect.height));

                if (roiW < 10 || roiH < 10) {
                    alert("각막 영역이 너무 작습니다.");
                    return;
                }

                let rect = new cv.Rect(roiX, roiY, roiW, roiH);
                let templateRgba = markingSnapshot.roi(rect);
                limbusTemplate = new cv.Mat();
                cv.cvtColor(templateRgba, limbusTemplate, cv.COLOR_RGBA2GRAY, 0);
                templateRgba.delete(); 
                
                // 3단계: 트래킹 시작
                markingStep = 3;
                statusLabel.textContent = "트래킹 중...";
                btnAction.style.display = 'none';
                marker.style.display = 'none';
            }
        });

        // ---------------- 동시 이동(Pan) & 크기 조절(Zoom) 로직 ----------------
        function handleInteraction(e) {
            e.preventDefault(); 
            
            const canvasRect = canvasElement.getBoundingClientRect();
            const scaleX = videoElement.videoWidth / canvasRect.width;
            const scaleY = videoElement.videoHeight / canvasRect.height;

            // 라이브 비디오 (마킹 전): 카메라 광학 줌
            if (markingStep === 0) {
                if (e.type === 'touchstart' && e.touches && e.touches.length === 2) {
                    const touch1 = e.touches[0];
                    const touch2 = e.touches[1];
                    initialPinchDistance = Math.hypot(touch1.clientX - touch2.clientX, touch1.clientY - touch2.clientY);
                    initialHardwareZoom = currentHardwareZoom;
                } else if (e.type === 'touchmove' && e.touches && e.touches.length === 2) {
                    if (initialPinchDistance && cameraCapabilities && cameraCapabilities.zoom && videoTrack) {
                        const touch1 = e.touches[0];
                        const touch2 = e.touches[1];
                        const currentDist = Math.hypot(touch1.clientX - touch2.clientX, touch1.clientY - touch2.clientY);
                        const scale = currentDist / initialPinchDistance;
                        
                        let newZoom = initialHardwareZoom * scale;
                        newZoom = Math.max(cameraCapabilities.zoom.min, Math.min(newZoom, cameraCapabilities.zoom.max));
                        
                        videoTrack.applyConstraints({ advanced: [{ zoom: newZoom }] })
                            .then(() => { currentHardwareZoom = newZoom; })
                            .catch(err => console.error("줌 조절 실패", err));
                    }
                } else if (e.type === 'touchend' || e.type === 'touchcancel') {
                    initialPinchDistance = null;
                }
                return;
            }

            // 마킹 중 (1단계 각막, 2단계 동공)
            if (markingStep === 1 || markingStep === 2) {
                if (e.type === 'touchstart' || e.type === 'mousedown') {
                    if (e.touches && e.touches.length === 2) {
                        isDragging = false;
                        const touch1 = e.touches[0];
                        const touch2 = e.touches[1];
                        initialPinchDistance = Math.hypot(touch1.clientX - touch2.clientX, touch1.clientY - touch2.clientY);
                        initialMarkerWidth = markerRect.width;
                        lastMidpointX = (touch1.clientX + touch2.clientX) / 2;
                        lastMidpointY = (touch1.clientY + touch2.clientY) / 2;
                    } else if ((e.touches && e.touches.length === 1) || !e.touches) {
                        isDragging = true;
                        initialPinchDistance = null;
                        lastMidpointX = null;
                        lastMidpointY = null;
                        lastTouchX = e.touches ? e.touches[0].clientX : e.clientX;
                        lastTouchY = e.touches ? e.touches[0].clientY : e.clientY;
                    }
                } 
                else if (e.type === 'touchmove' || e.type === 'mousemove') {
                    if (e.touches && e.touches.length === 2) {
                        isDragging = false;
                        const touch1 = e.touches[0];
                        const touch2 = e.touches[1];
                        
                        const currentDist = Math.hypot(touch1.clientX - touch2.clientX, touch1.clientY - touch2.clientY);
                        const currentMidX = (touch1.clientX + touch2.clientX) / 2;
                        const currentMidY = (touch1.clientY + touch2.clientY) / 2;
                        
                        if (initialPinchDistance && lastMidpointX !== null && lastMidpointY !== null) {
                            const scale = currentDist / initialPinchDistance;
                            let newWidth = initialMarkerWidth * scale;
                            newWidth = Math.max(20, Math.min(newWidth, 600)); // 동공을 위해 최소 크기 20px로 완화
                            
                            const dx = (currentMidX - lastMidpointX) * scaleX;
                            const dy = (currentMidY - lastMidpointY) * scaleY;
                            
                            const centerX = markerRect.x + markerRect.width / 2 + dx;
                            const centerY = markerRect.y + markerRect.height / 2 + dy;
                            
                            markerRect.width = newWidth;
                            markerRect.height = newWidth;
                            markerRect.x = centerX - newWidth / 2;
                            markerRect.y = centerY - newWidth / 2;
                            updateMarkerUI();
                        }
                        lastMidpointX = currentMidX;
                        lastMidpointY = currentMidY;
                        
                    } else if (((e.touches && e.touches.length === 1) || (!e.touches && e.buttons === 1)) && isDragging) {
                        const currentX = e.touches ? e.touches[0].clientX : e.clientX;
                        const currentY = e.touches ? e.touches[0].clientY : e.clientY;
                        
                        if (lastTouchX !== null && lastTouchY !== null) {
                            const dx = (currentX - lastTouchX) * scaleX;
                            const dy = (currentY - lastTouchY) * scaleY;
                            markerRect.x += dx;
                            markerRect.y += dy;
                            updateMarkerUI();
                        }
                        lastTouchX = currentX;
                        lastTouchY = currentY;
                    }
                } 
                else if (e.type === 'touchend' || e.type === 'mouseup' || e.type === 'touchcancel') {
                    isDragging = false;
                    initialPinchDistance = null;
                    lastTouchX = null;
                    lastTouchY = null;
                    lastMidpointX = null;
                    lastMidpointY = null;
                }
            }
        }

        canvasElement.addEventListener('touchstart', handleInteraction, {passive: false});
        canvasElement.addEventListener('touchmove', handleInteraction, {passive: false});
        canvasElement.addEventListener('touchend', handleInteraction);
        canvasElement.addEventListener('touchcancel', handleInteraction);
        canvasElement.addEventListener('mousedown', handleInteraction);
        canvasElement.addEventListener('mousemove', handleInteraction);
        canvasElement.addEventListener('mouseup', handleInteraction);

        function updateMarkerUI() {
            const canvasRect = canvasElement.getBoundingClientRect();
            const scaleX = canvasRect.width / videoElement.videoWidth;
            const scaleY = canvasRect.height / videoElement.videoHeight;
            marker.style.width = `${markerRect.width * scaleX}px`;
            marker.style.height = `${markerRect.height * scaleY}px`;
            marker.style.left = `${(markerRect.x + markerRect.width/2) * scaleX + canvasRect.left}px`;
            marker.style.top = `${(markerRect.y + markerRect.height/2) * scaleY + canvasRect.top}px`;
        }

        function processVideo() {
            if (videoElement.videoWidth === 0 || !isCvReady) {
                requestAnimationFrame(processVideo);
                return;
            }

            const width = videoElement.videoWidth;
            const height = videoElement.videoHeight;
            
            if (canvasElement.width !== width) {
                canvasElement.width = width;
                canvasElement.height = height;
            }

            canvasCtx.save();
            canvasCtx.clearRect(0, 0, width, height);
            
            // 3단계: 트래킹 상태
            if (markingStep === 3 && limbusTemplate != null) {
                canvasCtx.drawImage(videoElement, 0, 0, width, height);
                const imgData = canvasCtx.getImageData(0, 0, width, height);
                
                let src = null, srcGray = null, dst = null, mask = null; 
                
                try {
                    src = cv.matFromImageData(imgData);
                    srcGray = new cv.Mat();
                    cv.cvtColor(src, srcGray, cv.COLOR_RGBA2GRAY, 0);
                    
                    if (srcGray.cols >= limbusTemplate.cols && srcGray.rows >= limbusTemplate.rows) {
                        dst = new cv.Mat();
                        mask = new cv.Mat(); 
                        
                        // OpenCV: 각막 템플릿 매칭 수행
                        cv.matchTemplate(srcGray, limbusTemplate, dst, cv.TM_CCORR_NORMED, mask);
                        let result = cv.minMaxLoc(dst);
                        
                        if (result.maxVal > 0.82) {
                            // 각막 중심점 갱신
                            trackedCenter = new cv.Point(
                                result.maxLoc.x + corneaTrackingRadius,
                                result.maxLoc.y + corneaTrackingRadius
                            );
                        }
                    }
                } catch (err) {
                    markingStep = 0; 
                    alert("OpenCV 트래킹 에러. 초기화합니다.");
                    btnCaptureSnapshot.textContent = "마킹 스냅샷 찍기";
                    btnAction.style.display = 'none';
                    if (markingSnapshot) { markingSnapshot.delete(); markingSnapshot = null; }
                    if (limbusTemplate) { limbusTemplate.delete(); limbusTemplate = null; }
                    trackedCenter = null;
                } finally {
                    if (src) src.delete();
                    if (srcGray) srcGray.delete();
                    if (dst) dst.delete();
                    if (mask) mask.delete();
                }
            } 
            // 1, 2단계: 마킹 스냅샷 화면 표시
            else if ((markingStep === 1 || markingStep === 2) && markingSnapshot) {
                const tempCanvas = document.createElement('canvas');
                tempCanvas.width = width; tempCanvas.height = height;
                cv.imshow(tempCanvas, markingSnapshot);
                canvasCtx.drawImage(tempCanvas, 0, 0);
                
                // 동공 마킹 단계일 때 각막 위치를 희미하게 표시해 줌
                if (markingStep === 2 && corneaRect) {
                    canvasCtx.beginPath();
                    canvasCtx.arc(corneaRect.x + corneaTrackingRadius, corneaRect.y + corneaTrackingRadius, corneaTrackingRadius, 0, 2 * Math.PI);
                    canvasCtx.strokeStyle = 'rgba(0, 255, 255, 0.4)';
                    canvasCtx.lineWidth = 2;
                    canvasCtx.stroke();
                }
            } 
            // 0단계: 라이브 비디오
            else {
                canvasCtx.drawImage(videoElement, 0, 0, width, height);
            }

            // HUD 오버레이 그리기 (트래킹 중일 때)
            if (markingStep === 3 && trackedCenter) {
                // 1. 각막 (추적) 위치 계산
                const corneaCx = trackedCenter.x;
                const corneaCy = trackedCenter.y;
                
                // 2. 동공 (HUD) 위치 계산 = 각막 위치 + 오차율(Angle Kappa)
                const pupilCx = corneaCx + centerOffset.dx;
                const pupilCy = corneaCy + centerOffset.dy;

                // --- 각막 표시 (초록 원) ---
                canvasCtx.beginPath();
                canvasCtx.arc(corneaCx, corneaCy, corneaTrackingRadius, 0, 2 * Math.PI);
                canvasCtx.strokeStyle = '#00FF00';
                canvasCtx.lineWidth = 2;
                canvasCtx.stroke();

                // --- 동공 표시 (자주색 원) ---
                canvasCtx.beginPath();
                canvasCtx.arc(pupilCx, pupilCy, pupilTrackingRadius, 0, 2 * Math.PI);
                canvasCtx.strokeStyle = '#FF00FF';
                canvasCtx.lineWidth = 2;
                canvasCtx.stroke();

                // 동공 중심점 마커 (빨간 점)
                canvasCtx.beginPath();
                canvasCtx.arc(pupilCx, pupilCy, 3, 0, 2 * Math.PI);
                canvasCtx.fillStyle = '#FF0000';
                canvasCtx.fill();

                // --- 모든 가이드라인은 '동공(pupil)'을 중심으로 그립니다 ---
                const lineLength = corneaTrackingRadius + 150;

                // 0-180도 수평선 (시안색)
                canvasCtx.beginPath();
                canvasCtx.moveTo(pupilCx - lineLength, pupilCy);
                canvasCtx.lineTo(pupilCx + lineLength, pupilCy);
                canvasCtx.strokeStyle = '#00FFFF';
                canvasCtx.lineWidth = 2;
                canvasCtx.stroke();

                // 목표 난시 축 선 (노란색 점선)
                const userAngle = parseFloat(angleInput.value) || 0;
                const angleRad = -userAngle * (Math.PI / 180); 
                
                const endX1 = pupilCx + lineLength * Math.cos(angleRad);
                const endY1 = pupilCy + lineLength * Math.sin(angleRad);
                const endX2 = pupilCx - lineLength * Math.cos(angleRad);
                const endY2 = pupilCy - lineLength * Math.sin(angleRad);

                canvasCtx.beginPath();
                canvasCtx.setLineDash([12, 8]);
                canvasCtx.moveTo(endX2, endY2);
                canvasCtx.lineTo(endX1, endY1);
                canvasCtx.strokeStyle = '#FFFF00';
                canvasCtx.lineWidth = 4;
                canvasCtx.stroke();
                canvasCtx.setLineDash([]);
            }
            
            canvasCtx.restore();
            requestAnimationFrame(processVideo);
        }
    </script>
